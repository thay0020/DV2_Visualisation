{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Expenditure Components of Domestic Visitors", "fontSize": 16},
  "width": 350,
  "height": 350,
  "data": {"url": "expenditure_components.json"},
  "mark": {"type": "arc", "tooltip": true},
  "encoding": {
    "theta": {
        "field": "percentage",
        "type": "quantitative"
    },
    "order": {
        "field": "percentage",
        "type": "quantitative",
        "sort": "descending"
    },
    "color": {
      "field": "component",
      "type": "nominal",
      "title": "Component",
      "scale": {"scheme": "set2"},
      "legend": {"titleFontSize": 12, "labelFontSize": 11}
    },
    "tooltip": [
      {"field": "component", "title": "Component"},
      {"field": "percentage", "title": "Percentage (%)", "format": ".1f"}
    ]
  }
}
