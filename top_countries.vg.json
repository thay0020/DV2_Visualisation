{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {"text": "Top Visitor Arrivals by Country (Jan-Apr 2025)", "fontSize": 16},
  "width": 500,
  "height": 300,
  "data": {"url": "top_countries.json"},
  "layer": [
    {
      "mark": {"type": "bar", "tooltip": true},
      "encoding": {
        "x": {
          "field": "arrivals",
          "type": "quantitative",
          "title": "Visitor Arrivals"
        },
        "y": {
          "field": "country",
          "type": "nominal",
          "title": "Country",
          "sort": "-x"
        },
        "color": {
        "field": "growth",
        "type": "quantitative",
        "bin": {
            "maxbins": 4
        },
        "title": "Growth (%) (binned)",
        "scale": {
            "scheme": "teals"
        },
        "legend": {
            "titleFontSize": 12,
            "labelFontSize": 11
        }
        },
        "tooltip": [
          {"field": "country", "title": "Country"},
          {"field": "arrivals", "title": "Arrivals", "format": ","},
          {"field": "growth", "title": "Growth (%)", "format": ".1f"}
        ]
      }
    }
  ]
}
